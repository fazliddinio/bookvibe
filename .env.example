# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database (PostgreSQL)
DATABASE_ENGINE=django.db.backends.postgresql
DB_NAME=bookvibe_db
DB_USER=bookvibe_user
DB_PASSWORD=bookvibe_password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://127.0.0.1:6379/1

# Celery
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=django-db
CELERY_TASK_ALWAYS_EAGER=False

# Email (console backend by default — no real emails sent)
ENABLE_EMAIL_SENDING=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@bookvibe.com

# Site
SITE_URL=http://localhost:8000

# Security (set these in production)
SECURE_SSL_REDIRECT=False
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Google OAuth (optional)
ENABLE_GOOGLE_LOGIN=False
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# External APIs (optional)
GOOGLE_BOOKS_API_KEY=
OPENAI_API_KEY=
COHERE_API_KEY=
ANTHROPIC_API_KEY=

# Sentry (optional, for production error tracking)
SENTRY_DSN=

# Docker-specific (only used in docker-compose.yml)
# WEB_PORT=8080
# MOUNT_CODE=./
# NETWORK_EXTERNAL=false
# NETWORK_NAME=bookvibe_network
